# KPB Education — Docker Compose environment template.
# Copy to `.env`, fill production secrets, and never commit the real file.

# Release identity. In production use the immutable Git SHA or release version.
KPB_IMAGE_TAG=local
# Exact Git commit embedded in immutable impact snapshots once the platform is on.
KPB_BUILD_SHA=
TZ=Africa/Niamey
KPB_ADMIN_API_BASE_URL=https://api.kpbeducation.cloud/api

# PostgreSQL and backups
POSTGRES_USER=kpb
POSTGRES_PASSWORD=
POSTGRES_DB=kpb
BACKUP_KEEP_DAYS=14

# Required API security configuration
KPB_JWT_SECRET=
KPB_JWT_REFRESH_SECRET=
KPB_ADMIN_REFRESH_SECRET=
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=https://admin.kpbeducation.cloud
KPB_TRUST_PROXY_HOPS=1

# Mobile release gates
KPB_MIN_APP_VERSION=0.0.0
KPB_ANDROID_STORE_URL=
KPB_IOS_STORE_URL=
KPB_MVP_ONLY=true

# Scholarship auto-refresh (KPB-161): true = run the 48h scrape of vetted
# sources (GreatYop, MastereTn). Independent of KPB_MVP_ONLY, so enabling it
# never unlocks other MVP-gated surfaces. Admin "Refresh now" works regardless,
# as does the daily catalog-freshness SLA check (WARN log on overdue items).
KPB_SCHOLARSHIP_REFRESH_ENABLED=false

# Daily "Bourse du jour" push (KPB-162): true = push the featured scholarship at
# 19h local time. OFF by default until the Home card + opt-out toggle ship; the
# GET /scholarships/daily endpoint works regardless.
KPB_DAILY_SCHOLARSHIP_ENABLED=false

# Optional integrations
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
RESEND_API_KEY=
# Newsletter bourses (Mautic auto-hébergé — stack marketing du même VPS).
# Activer l'API dans Mautic (Configuration → API Settings → Basic Auth) et
# créer le segment ; laisser vide pour désactiver la synchronisation.
MAUTIC_BASE_URL=https://mautic.kpbeducation.cloud
MAUTIC_USERNAME=
MAUTIC_PASSWORD=
MAUTIC_SEGMENT_ID=
KPB_MAGIC_LINK_FROM=KPB Education <no-reply@kpbeducation.cloud>
# Lien web optionnel ajouté aux emails magic-link. NE PAS renseigner tant
# qu'aucun vérificateur web n'existe : app.kpbeducation.cloud pointe sur
# l'hébergement marketing (185.158.133.1), pas sur l'API — le lien serait mort.
# Le code à 6 chiffres et le lien kpb:// suffisent.
KPB_MAGIC_LINK_WEB_BASE=
KPB_CAMPAIGN_MAIL_FROM=
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=
KPB_KAYAK_API_KEY=
KPB_KAYAK_BASE_URL=https://api.kayak.com
KPB_KAYAK_USER_AGENT=

# Private object storage. Leave blank to use the persisted local volume.
KPB_S3_ENDPOINT=
KPB_S3_REGION=fr-par
KPB_S3_BUCKET=
KPB_S3_ACCESS_KEY_ID=
KPB_S3_SECRET_ACCESS_KEY=
KPB_S3_PUBLIC_BASE_URL=
KPB_S3_FORCE_PATH_STYLE=false
KPB_UPLOADS_DIR=/app/uploads
KPB_UPLOADS_PUBLIC_URL=
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Competition Readiness — fail closed by default.
KPB_COMPETITION_READINESS_ENABLED=false
KPB_SUCCESS_LAB_ENABLED=false
KPB_APPLICATION_ARTIFACTS_ENABLED=false
KPB_APPLICATION_ARTIFACT_MAX_BYTES=10485760
KPB_STUDY_REVIEW_ENABLED=false
KPB_STUDY_REVIEW_SLA_HOURS=48
KPB_EVIDENCE_ACCESS_TTL_SECONDS=60
KPB_EVIDENCE_ACCESS_SECRET=
KPB_AI_DIAGNOSTIC_ENABLED=false
KPB_AI_DIAGNOSTIC_KILL_SWITCH=true
KPB_AI_DIAGNOSTIC_MODEL=
KPB_AI_DIAGNOSTIC_MIN_AGE=13
KPB_AI_DIAGNOSTIC_PROMPT_VERSION=success-lab-v1
KPB_AI_DIAGNOSTIC_MAX_INPUT_CHARS=8000
KPB_AI_DIAGNOSTIC_MAX_BILLABLE_INPUT_TOKENS=12000
KPB_AI_DIAGNOSTIC_MAX_OUTPUT_TOKENS=220
KPB_AI_DIAGNOSTIC_DAILY_CALL_CAP=100
KPB_AI_DIAGNOSTIC_USER_DAILY_ATTEMPT_CAP=3
KPB_AI_DIAGNOSTIC_MONTHLY_BUDGET_MICROS_USD=0
KPB_AI_DIAGNOSTIC_PRICE_VERSION=
KPB_AI_DIAGNOSTIC_CRITERIA_MAX_AGE_DAYS=180
KPB_SUCCESS_LAB_PILOT_COUNTRIES=NE,SN,CI
KPB_SUCCESS_LAB_ROLLOUT_PERCENT=0
KPB_FEATURE_ROLLOUT_SECRET=
KPB_ANALYTICS_ACTOR_SECRET=
# Durable domain-event worker. Defaults are suitable for one or several API
# replicas; tune only with backlog/latency evidence.
KPB_OUTBOX_BATCH_SIZE=10
KPB_OUTBOX_LEASE_MS=300000
KPB_OUTBOX_MAX_ATTEMPTS=8
KPB_OUTBOX_RETRY_BASE_MS=5000
KPB_OUTBOX_RETRY_CAP_MS=3600000
KPB_OUTCOME_EVIDENCE_ENABLED=false
KPB_OUTCOME_EVIDENCE_MAX_PENDING_PER_WORKSPACE=20
KPB_OUTCOME_REFERENCE_HMAC_SECRET=
KPB_IMPACT_PUBLIC_STATS_ENABLED=false

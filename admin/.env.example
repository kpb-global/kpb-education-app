# KPB Education — admin web app environment.
# Copy to `.env.local` for dev, or set in the deploy/CI build env for production.
#
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at BUILD time. The production admin
# bundle must be built with this set to the real API origin, otherwise it falls
# back to http://127.0.0.1:4000/api and the deployed admin can't reach the API.
NEXT_PUBLIC_KPB_API_BASE_URL=https://api.kpbeducation.com/api

{
  "name": "kpb-education-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:countries": "bash scripts/seed-countries.sh",
    "seed:counsellors": "bash -lc 'set -a; source .env; set +a; PSQL_URL=$(printf \"%s\" \"$DATABASE_URL\" | sed -E \"s/[?&]schema=[^&]*//g\" | sed -E \"s/\\?&/?/g\"); psql \"$PSQL_URL\" -f scripts/seed-kpb-counsellors.sql'",
    "import:omnes": "ts-node scripts/import-omnes-template.ts",
    "import:omnes:bundled": "ts-node scripts/import-omnes-template.ts scripts/data/omnes_fall_26.xlsx",
    "seed:omnes": "ts-node scripts/seed-omnes-programs.ts",
    "seed:partners": "ts-node scripts/seed-partner-schools.ts",
    "seed:countries-m5": "ts-node scripts/seed-countries-m5.ts",
    "seed:catalogue-unique": "ts-node scripts/seed-catalogue-unique.ts",
    "seed:catalog": "npm run seed:countries-m5 && npm run seed:omnes && npm run seed:partners && npm run seed:catalogue-unique",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@nestjs/common": "10.4.22",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/platform-socket.io": "10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "10.4.22",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "jest": "^30.3.0",
    "prisma": "^6.6.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}

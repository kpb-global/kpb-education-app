  marketingDescriptionEn String                  @default("")
  whyStudyBulletsFr      String[]                @default([])
  whyStudyBulletsEn      String[]                @default([])
  howItWorksFr           String                  @default("")
  howItWorksEn           String                  @default("")
  costsOverviewFr        String                  @default("")
  costsOverviewEn        String                  @default("")
  languageSectionFr      String                  @default("")
  languageSectionEn      String                  @default("")
  partnerSchoolsFr       String                  @default("")
  partnerSchoolsEn       String                  @default("")
  scholarshipsSectionFr  String                  @default("")

model CaseDocument {
  id             String    @id @default(cuid())
  caseId         String
  title          String
  fileUrl        String?
  uploadedAt     DateTime?
  isProvided     Boolean   @default(false)
  // ── Commercial per-document review (Feature D) ──────────────────────────
  // Counsellor verdict on an uploaded document. Allowed values:

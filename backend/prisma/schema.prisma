model UserProfile {
  id                      String                         @id @default(cuid())
  accountType             AccountType
  // Supabase Auth user id (JWT `sub`). Null for legacy/home-grown accounts
  // not yet migrated. Used by SupabaseAuthGuard to map a verified token to a
  // local profile.
  supabaseUserId          String?                        @unique
  preferredLanguage       String
  fullName                String
  email                   String                         @unique
  phone                   String
  whatsApp                String?
  countryOfResidence      String
  currentLevel            String?
  targetLevel             String?
  languageLevel           String?
  gradeRange              String?
  // Legacy monthly living budget. Read only for backward compatibility.
  monthlyBudgetEur        Int?
  // Annual tuition budget is the canonical financial input for matching.
  annualTuitionBudgetEur  Int?
  // EUR is the canonical stored unit; this is only the user's display choice.
  preferredCurrency       String                         @default("XOF")
  wantsScholarship        Boolean                        @default(false)
  // Per-user interest selections (previously held in a shared in-memory
  // singleton, which leaked across users). Now persisted per profile.
  fieldIds                String[]                       @default([])
  targetCountryIds        String[]                       @default([])
  availableDocuments      String[]                       @default([])
  consentedAt             DateTime?
  // Separate, explicit consent for third-party AI processing (Groq). Gates the
  // AI coach independently of the general onboarding consent above.
  aiConsentedAt           DateTime?
  // Scholarship-newsletter opt-in (Mautic). `newsletterOptIn` is the user's
  // current desired state; `newsletterConsentedAt` is the timestamped proof of
  // the latest opt-in (GDPR); `newsletterSyncedOptIn` is the last state
  // actually pushed to Mautic (null = never synced). The reconciliation cron
  // syncs every profile where desired != synced, so a failed push self-heals.
  newsletterOptIn         Boolean                        @default(false)
  newsletterConsentedAt   DateTime?
  newsletterSyncedOptIn   Boolean?
  // KPB-162: opt-out of the daily "Bourse du jour" push (the "opportunités"
  // notification type). false = opted in; the daily cron skips users set true.
  // Opting out never affects other notifications (deadlines, dossier, etc.).
  dailyScholarshipOptOut  Boolean                        @default(false)
  // Age gate + self-attested guardian consent for declared minors (<18).
  // guardianConsentedAt gates data sync and AI processing for minors.
  birthDate               DateTime?
  guardianName            String?
  guardianContact         String?
  guardianConsentedAt     DateTime?
  // Last time the profile-completion nudge (KPB-76) was sent — throttles the
  // re-engagement push so an incomplete profile is reminded at most monthly.
  profileNudgedAt         DateTime?
  // Stable per-student referral code (KPB-69) — generated on first read, shared
  // via WhatsApp. Friends who redeem it are attributed back to this profile.
  referralCode            String?                        @unique
  // No-cash referral rewards (KPB-77). Denormalized credit balance: +1 when a
  // referee reaches the first-case milestone, spent into a WhatsApp advisor
  // voucher. The signed CreditTransaction log is the audit trail and reconciles
  // this counter via SUM(amount); both are always written in one $transaction.
  reviewCredits           Int                            @default(0)
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  cases                   Case[]
  appointments            Appointment[]
  savedItems              SavedItem[]
  partnerLead             PartnerLead?
  credential              StudentCredential?
  deviceTokens            DeviceToken[]
  purchases               AcademyPurchase[]
  parentLinksAsParent     ParentChildLink[]              @relation("parentLink_parent")
  parentLinksAsChild      ParentChildLink[]              @relation("parentLink_child")
  paymentIntents          PaymentIntent[]
  // ── Phase 3 — Alumni mentor layer ─────────────────────────────────────────
  // Students who got admitted become verified mentors with a badge in the
  // community. We keep the fields flat on UserProfile (rather than a separate
  // Mentor model) because the identity is the same — it's a status, not a new
  // account type. Admin flips `alumniStatus` to `approved` after reviewing the
  // acceptance letter uploaded via `alumniProofUrl`.
  alumniStatus            AlumniVerificationStatus       @default(none)
  alumniUniversity        String?
  alumniProgramme         String?
  alumniGraduationYear    Int?
  alumniCountryCode       String? // ISO 3166-1 alpha-2
  alumniBioFr             String?
  alumniBioEn             String?
  alumniProofUrl          String? // Admission letter / degree — admin-only
  alumniVerifiedAt        DateTime?
  alumniVerifiedById      String? // AdminUser.id (no FK — keep decoupled)
  alumniBadgeVisible      Boolean                        @default(true)
  servicePurchases        ServicePurchase[]
  salonRegistrations      SalonRegistration[]
  referralsMade           Referral[]                     @relation("referral_referrer")
  referralReceived        Referral?                      @relation("referral_referee")
  creditTransactions      CreditTransaction[]
  matches                 Match[]
  scholarshipAlerts       ScholarshipAlertSubscription[]
  userNotifications       UserNotification[]
  consentReceipts         ConsentReceipt[]
  scholarshipWorkspaces   ScholarshipWorkspace[]
  aiQuotaBuckets          AiQuotaBucket[]
  outcomeEvidenceAssets   OutcomeEvidenceAsset[]
  outcomeEvidenceLinks    OutcomeEvidenceLink[]
  impactCohortMemberships ImpactCohortMembership[]

  @@index([accountType])
  @@index([createdAt])
  @@index([alumniStatus])
}

// WhatsApp-native referral attribution (KPB-69). One row per redeemed referral:
// the referrer (code owner) → the referee (the friend who redeemed). A profile
// can be referred at most once (`refereeProfileId @unique`). The "case created"
// milestone is derived on read (referee has ≥1 case), so no write-side hook.
model Referral {
  id               String      @id @default(cuid())
  referrerId       String
  refereeProfileId String      @unique
  createdAt        DateTime    @default(now())
  referrer         UserProfile @relation("referral_referrer", fields: [referrerId], references: [id])
  referee          UserProfile @relation("referral_referee", fields: [refereeProfileId], references: [id])

  @@index([referrerId])
}

// No-cash referral rewards ledger (KPB-77). Append-only, signed-amount log of
// every credit movement. Earns are +N (referee reached the first-case
// milestone); spends are −N (redeemed into a WhatsApp advisor voucher). The
// `dedupeKey` @unique is the entire idempotency mechanism: earns are keyed
// `firstcase:<referralId>` (credit a referrer at most once per referral, ever);
// spends are keyed `voucher:<clientRef>` (a retried redeem tap cannot
// double-spend). Reading the balance is the denormalized UserProfile.reviewCredits
// counter; this table is the audit trail that reconciles it via SUM(amount).
enum CreditReason {
  referralFirstCase // +N earn: referee created their 1st case
  reviewVoucherRedeemed // −N spend: redeemed into an advisor review voucher
  adminAdjust // +/−N manual ops correction (reserved)
}

model CreditTransaction {
  id        String       @id @default(cuid())
  profileId String // owner whose balance moved (the REFERRER on an earn)
  amount    Int // signed: + earn / − spend; never 0
  reason    CreditReason
  dedupeKey String       @unique // earn: firstcase:<referralId> | spend: voucher:<clientRef>
  metadata  Json? // e.g. { refereeId } on earn, { voucherCode } on spend — NO PII
  createdAt DateTime     @default(now())
  profile   UserProfile  @relation(fields: [profileId], references: [id])

  @@index([profileId])
}

model StudentCredential {
  id            String      @id @default(cuid())
  userProfileId String      @unique
  email         String      @unique
  passwordHash  String
  refreshToken  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
}

/// Email magic-link / one-time code tokens (purged after use or expiry).
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model DeviceToken {
  id            String      @id @default(cuid())
  userProfileId String
  token         String      @unique
  platform      String
  createdAt     DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])

  @@index([userProfileId])
}

model Case {
  id                          String                 @id @default(cuid())
  referenceCode               String                 @unique
  // DB-assigned monotonic counter used to build a collision-free
  // referenceCode (replaces the racy count()+1 scheme).
  seq                         Int                    @unique @default(autoincrement())
  userId                      String
  type                        CaseType
  status                      CaseStatus
  title                       String
  description                 String
  contextLabel                String
  nextStepTitle               String
  nextStepDescription         String
  assignedAdvisorName         String?
  assignedAdvisorPhone        String?
  assignedAdvisorWhatsapp     String?
  source                      String                 @default("mobile_app")
  requestedCountryId          String?
  preferredContactMethod      String                 @default("in_app")
  scheduledAt                 DateTime?
  // ── Marketplace (Track B) ───────────────────────────────────────────────
  counsellorId                String?
  // ── Parent mode (Track C1) ──────────────────────────────────────────────
  parentCanView               Boolean                @default(false)
  // ── Phase 3 — Zero-friction entry ───────────────────────────────────────
  freeMessageConsumed         Boolean                @default(false)
  // ── M9 Commercial ops ───────────────────────────────────────────────────
  leadTag                     String?
  discussionMotive            String?
  lastCommercialInteractionAt DateTime?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  user                        UserProfile            @relation(fields: [userId], references: [id])
  counsellor                  Counsellor?            @relation(fields: [counsellorId], references: [id])
  messages                    CaseMessage[]
  timelineEvents              CaseTimelineEvent[]
  tasks                       CaseTask[]
  documents                   CaseDocument[]
  appointments                Appointment[]
  internalNotes               CaseInternalNote[]
  notificationDeliveries      NotificationDelivery[]
  paymentIntents              PaymentIntent[]
  servicePurchases            ServicePurchase[]
  studyReviewRequest          StudyReviewRequest?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([leadTag])
  @@index([type])
  @@index([counsellorId])
}

model CaseMessage {
  id         String   @id @default(cuid())
  caseId     String
  senderRole String
  senderName String
  body       String
  createdAt  DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([createdAt])
}


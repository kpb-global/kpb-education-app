  livingCostRangeEn      String
  visaOverviewFr         String
  visaOverviewEn         String
  admissionDifficultyFr  String
  admissionDifficultyEn  String
  popularFieldIds        String[]
  displayOrder           Int                     @default(0)
  isActive               Boolean                 @default(true)
  // Data-trust signal: when the facts were last confirmed, and the source.
  lastVerifiedAt         DateTime?
  sourceUrl              String?
  verifiedById           String?
  verifiedByName         String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  eligibilityQuiz        CountryEligibilityQuiz?

  @@index([isActive, displayOrder])
  @@index([lastVerifiedAt])
}

model CountryEligibilityQuiz {
  id        String   @id @default(cuid())
  countryId String   @unique
  questions Json
  verdicts  Json
  createdAt DateTime @default(now())
  // The original M5 migration created a database-side CURRENT_TIMESTAMP
  // default; keep the Prisma model aligned with that canonical history.
  updatedAt DateTime @default(now()) @updatedAt
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
}

model Institution {
  id                     String             @id @default(cuid())
  nameFr                 String
  nameEn                 String
  countryId              String
  locationFr             String
  locationEn             String
  overviewFr             String
  overviewEn             String
  studyLevels            String[]
  tuitionLabelFr         String
  tuitionLabelEn         String
  languageRequirementsFr String
  languageRequirementsEn String
  intakePeriods          String[]
  programIds             String[]
  isPartner              Boolean            @default(false)
  lastVerifiedAt         DateTime?
  sourceUrl              String?
  verifiedById           String?
  verifiedByName         String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  partnerAgreements      PartnerAgreement[]

  @@index([countryId])
  @@index([lastVerifiedAt])
}

model Program {
  id                  String    @id @default(cuid())
  institutionId       String
  countryId           String
  fieldId             String
  nameFr              String
  nameEn              String
  levelFr             String
  levelEn             String
  durationFr          String
  durationEn          String
  tuitionFr           String
  tuitionEn           String
  languageFr          String
  languageEn          String
  requirementsFr      String[]
  requirementsEn      String[]
  // Multi-campus formations (OMNES, and any future school whose programme is
  // delivered on several campuses). Same formation = one Program row; the
  // per-campus price/intake live here instead of duplicating the row.
  // Null for single-campus programs. Shape:
  // [{ campus: string, tuitionUpfront: number|null,
  //    tuitionInstallments: number|null, intake: string|null }]
  campusOfferings     Json?
  // ── Match scoring inputs (Phase 0 / P0-D, kit matching_algorithm.md) ──────
  // Nullable on purpose: the scoring service treats a missing value as a
  // neutral 0.5 factor and flags the match `isEstimate`, so no backfill is
  // required to ship. Populating these per program is a catalog/ops task.
  // `tuitionFr/En` above stay the human-readable labels; `tuitionMinEur` is
  // the machine-readable floor used for budget scoring.
  minGpaRequired      Float?
  tuitionMinEur       Int?
  applicationDeadline DateTime?
  teachingLanguages   String[]  @default([])
  lastVerifiedAt      DateTime?
  sourceUrl           String?
  verifiedById        String?
  verifiedByName      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([institutionId])
  @@index([countryId])
  @@index([fieldId])
  @@index([lastVerifiedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Admission-probability matches (Phase 0 / P0-D — kit US-003/US-004)
// ─────────────────────────────────────────────────────────────────────────────

enum MatchZone {
  green // probability > 0.70
  yellow // 0.30–0.70
  blue // < 0.30
}

// One scored (user, program) pair. Rows are a 24h cache of the deterministic
// v1 scoring (see MatchesService) — safe to delete wholesale; they are always
// recomputable. `programId` is a plain string like every other catalog
// reference in this schema (catalog rows may come from the mock fallback, so
// no FK). The UserProfile FK cascades so GDPR deleteMe needs no extra step.
model Match {
  id               String            @id @default(cuid())
  userProfileId    String
  programId        String
  institutionId    String
  probability      Float
  zone             MatchZone
  algorithmVersion String            @default("v1")
  // True when ≥1 scoring input was missing and defaulted to neutral 0.5 —
  // mobile shows "Estimation — complète ton dossier pour plus de précision".
  isEstimate       Boolean           @default(false)
  expiresAt        DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userProfile      UserProfile       @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  explanation      MatchExplanation?

  @@unique([userProfileId, programId])
  @@index([userProfileId])
  @@index([programId])
  @@index([expiresAt])
}

// Per-factor breakdown + human narrative for one match. `factors` is the kit
// contract shape: [{ name, weight, score, isEstimate }].
model MatchExplanation {
  id          String   @id @default(cuid())
  matchId     String   @unique
  factors     Json
  narrativeFr String   @default("")
  narrativeEn String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Scholarship {
  id                     String                         @id @default(cuid())
  nameFr                 String
  nameEn                 String
  countryId              String
  countryNameFr          String                         @default("")
  countryNameEn          String                         @default("")
  levelEligibleFr        String
  levelEligibleEn        String
  typeOfFundingFr        String
  typeOfFundingEn        String
  fundingType            FundingType                    @default(unknown)
  applicationRequirement ApplicationRequirement         @default(separate_application)
  deadlineLabelFr        String
  deadlineLabelEn        String
  descriptionFr          String                         @default("")
  descriptionEn          String                         @default("")
  advantagesFr           String[]                       @default([])
  advantagesEn           String[]                       @default([])
  eligibilityFr          String[]                       @default([])
  eligibilityEn          String[]                       @default([])
  keyRequirementsFr      String[]
  keyRequirementsEn      String[]
  relatedFieldIds        String[]
  baseMatch              Int                            @default(30)
  academyCourseId        String?
  // ── Live-index fields (Track A1) ────────────────────────────────────────
  // Populated by the 48h refresh job; null for legacy seed data.
  sourceKey              String?                        @unique // e.g. "greatyop-ajinomoto-2026"
  sourceUrl              String?
  applicationUrl         String?
  deadlineAt             DateTime?
  lastVerifiedAt         DateTime?
  verifiedById           String?
  verifiedByName         String?
  isActive               Boolean                        @default(true)
  // Approved for curated/seeded rows; scraper inserts land as pending.
  moderationStatus       ScholarshipModeration          @default(approved)
  tags                   String[]                       @default([])
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  academyCourse          AcademyCourse?                 @relation(fields: [academyCourseId], references: [id])
  applicationSteps       ScholarshipApplicationStep[]
  videos                 ScholarshipVideo[]
  cycles                 ScholarshipCycle[]
  alertSubscriptions     ScholarshipAlertSubscription[]
  userNotifications      UserNotification[]
  workspaces             ScholarshipWorkspace[]

  @@index([countryId])
  @@index([deadlineAt])
  @@index([lastVerifiedAt])
  @@index([isActive])
  @@index([fundingType])
  @@index([moderationStatus])
}

// Annual application window. Estimated dates may be seeded from the previous
// cycle; `opensAt`/`closesAt` are the dates confirmed by an admin at launch.
model ScholarshipCycle {
  id               String                    @id @default(cuid())
  scholarshipId    String
  academicYear     String
  status           ScholarshipCycleStatus    @default(forecast)
  dateConfidence   ScholarshipDateConfidence @default(estimated)
  estimatedOpenAt  DateTime?
  estimatedCloseAt DateTime?
  opensAt          DateTime?
  closesAt         DateTime?
  sourceUrl        String?
  verifiedAt       DateTime?
  activatedAt      DateTime?
  activationKey    String?                   @unique
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  scholarship      Scholarship               @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  workspaces       ScholarshipWorkspace[]

  @@unique([scholarshipId, academicYear])
  @@index([scholarshipId, status])
  @@index([estimatedOpenAt])
  @@index([opensAt])
  @@index([closesAt])
}

// Explicit opt-in behind the mobile "M'avertir" action.
model ScholarshipAlertSubscription {
  id            String      @id @default(cuid())
  userId        String
  scholarshipId String
  pushEnabled   Boolean     @default(true)
  inAppEnabled  Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
}

// Durable, per-user in-app feed. Scholarship activations use `dedupeKey` so an
// admin retry cannot create duplicate rows or duplicate push notifications.
model UserNotification {
  id            String       @id @default(cuid())
  userId        String
  scholarshipId String?
  kind          String
  dedupeKey     String       @unique
  titleFr       String
  titleEn       String
  bodyFr        String
  bodyEn        String
  route         String
  data          Json?
  readAt        DateTime?
  // When a push was actually delivered for this entry (NULL = feed-only: the
  // durable in-app notification was written but no push went out, e.g. it was
  // suppressed by quiet hours or the daily frequency cap). Also the counter the
  // dispatcher uses to enforce the per-user daily push cap.
  pushedAt      DateTime?
  createdAt     DateTime     @default(now())
  user          UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship   Scholarship? @relation(fields: [scholarshipId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, pushedAt])
  @@index([scholarshipId])
}

// Ordered, admin-authored "how to apply" steps for a specific scholarship
// (e.g. Chevening: online form then interview; MEXT: written exam). Distinct
// from the generic deadline countdown (RoadmapEngine) — these are curated
// per scholarship, never scraped.
model ScholarshipApplicationStep {
  id                     String                     @id @default(cuid())
  scholarshipId          String
  stepNumber             Int
  titleFr                String
  titleEn                String
  descriptionFr          String                     @default("")
  descriptionEn          String                     @default("")
  estimatedDurationDays  Int?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  scholarship            Scholarship                @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  workspaceStepSnapshots ScholarshipWorkspaceStep[]

  @@unique([scholarshipId, stepNumber])
  @@index([scholarshipId])
}

// Curated YouTube explainers attached from the admin scholarship editor.
// Store the stable video id instead of raw iframe HTML; clients build the
// canonical watch/share URLs and use their native YouTube player.
model ScholarshipVideo {
  id                 String            @id @default(cuid())
  scholarshipId      String
  youtubeVideoId     String
  titleFr            String
  titleEn            String
  descriptionFr      String            @default("")
  descriptionEn      String            @default("")
  thumbnailUrl       String?
  durationSeconds    Int?
  languageCode       String            @default("fr")
  youtubePublishedAt DateTime?
  status             PublicationStatus @default(draft)
  isFeatured         Boolean           @default(false)
  displayOrder       Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  scholarship        Scholarship       @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, youtubeVideoId])
  @@index([scholarshipId, status, displayOrder])
}

model AcademyCourse {
  id            String            @id @default(cuid())
  titleFr       String
  titleEn       String
  descriptionFr String
  descriptionEn String
  coverImageUrl String?
  priceXOF      Int
  priceEUR      Float
  status        PublicationStatus @default(draft)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lessons       AcademyLesson[]
  scholarships  Scholarship[]
  purchases     AcademyPurchase[]
}

model AcademyLesson {
  id              String        @id @default(cuid())
  courseId        String
  titleFr         String
  titleEn         String
  videoUrl        String
  durationSeconds Int
  order           Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  course          AcademyCourse @relation(fields: [courseId], references: [id])
}

model AcademyPurchase {
  id            String        @id @default(cuid())
  userId        String
  courseId      String
  transactionId String? // Reference to payment provider
  amountPaid    Float
  currency      String
  createdAt     DateTime      @default(now())
  user          UserProfile   @relation(fields: [userId], references: [id])
  course        AcademyCourse @relation(fields: [courseId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Counsellor marketplace (Track B)
// ─────────────────────────────────────────────────────────────────────────────

enum CounsellorKycStatus {
  pending
  under_review
  approved
  rejected
  suspended
}

model Counsellor {
  id                  String                       @id @default(cuid())
  fullName            String
  email               String                       @unique
  phone               String
  whatsApp            String?
  countryOfResidence  String
  // Freeform slug like "cs-bj", "med-ci" — used for filtering in admin/mobile.
  specialties         String[]                     @default([])
  // ISO 639-1 codes (e.g. ["fr","en","bm","wo"]).
  languagesSpoken     String[]                     @default([])
  bioFr               String
  bioEn               String
  yearsExperience     Int                          @default(0)
  // Hourly rate in XOF. Admin can override per-case in PaymentIntent.
  hourlyRateXOF       Int                          @default(0)
  // KPB take (basis points, 1000 = 10%). Default 15%.
  commissionBps       Int                          @default(1500)
  kycStatus           CounsellorKycStatus          @default(pending)
  kycNotes            String?
  kycVerifiedAt       DateTime?
  isActive            Boolean                      @default(false)
  avgRating           Float                        @default(0)
  reviewCount         Int                          @default(0)
  adminUserId         String?                      @unique
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  adminUser           AdminUser?                   @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  cases               Case[]
  reviews             CounsellorReview[]
  studyReviewRequests StudyReviewRequest[]
  availabilitySlots   CounsellorAvailabilitySlot[]
  appointments        Appointment[]

  @@index([kycStatus])
  @@index([isActive])
  @@index([countryOfResidence])
}

model CounsellorReview {
  id             String     @id @default(cuid())
  counsellorId   String
  reviewerName   String
  reviewerUserId String?
  caseId         String?
  rating         Int // 1–5
  body           String
  isPublished    Boolean    @default(false)
  createdAt      DateTime   @default(now())
  counsellor     Counsellor @relation(fields: [counsellorId], references: [id])

  @@index([counsellorId])
  @@index([isPublished])
}

// ─────────────────────────────────────────────────────────────────────────────
// Parent mode (Track C1)
// ─────────────────────────────────────────────────────────────────────────────

enum ParentLinkStatus {
  pending
  active
  revoked
}

model ParentChildLink {
  id         String           @id @default(cuid())
  parentId   String // UserProfile.id with accountType=parent
  // Null while the invite is pending — populated on accept.
  childId    String?
  inviteCode String           @unique
  status     ParentLinkStatus @default(pending)
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  parent     UserProfile      @relation("parentLink_parent", fields: [parentId], references: [id])
  child      UserProfile?     @relation("parentLink_child", fields: [childId], references: [id])

  @@unique([parentId, childId])
  @@index([childId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payment abstraction (Track C3) — CinetPay / Paydunya / Stripe
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentProvider {
  cinetpay
  paydunya
  stripe
  manual
}

enum PaymentStatus {
  created
  pending
  paid
  failed
  refunded
  cancelled
}

// ─────────────────────────────────────────────────────────────────────────────
// Visa appointment availability (Phase 1 — Track A2)
// ─────────────────────────────────────────────────────────────────────────────
// One row per consulate. Cron upserts by consulateCode so the mobile app
// can fetch the latest-known state cheaply. No history table — if we need
// trend analysis later, we'll add a separate append-only VisaAvailabilityLog.

model VisaAvailabilitySnapshot {
  id              String                 @id @default(cuid())
  // Stable slug like "canada-abidjan", "france-dakar". @unique so upsert
  // cleanly replaces the previous snapshot.
  consulateCode   String                 @unique
  // ISO 3166-1 alpha-2 of the destination (the country being travelled to).
  countryCode     String
  // City the consulate/TLS/VFS centre sits in — not the destination city.
  city            String
  // Earliest bookable appointment datetime, if known. Null for full/unknown.
  nextAvailableAt DateTime?
  // Human-readable label (e.g. "2 semaines", "5+ months", "fermé"). The
  // fetcher can set this even when it can't parse a concrete datetime.
  soonestSlot     String?
  lastCheckedAt   DateTime?
  status          VisaAvailabilityStatus @default(unknown)
  // If a fetch failed, the short error string — surfaced to admins only.
  errorMessage    String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([countryCode])
  @@index([status])
}

model PaymentIntent {
  id              String           @id @default(cuid())
  userId          String // payer (often a parent)
  caseId          String?
  // Allows paying a counsellor directly without a case (unusual but possible).
  counsellorId    String?
  // XOF is integer (no subdivision); other currencies kept as integer minor units.
  amountMinor     Int
  currency        String           @default("XOF")
  provider        PaymentProvider
  // Provider's own id for the transaction (e.g. CinetPay transaction_id).
  providerRef     String?          @unique
  // Provider-hosted checkout URL returned by init call.
  checkoutUrl     String?
  status          PaymentStatus    @default(created)
  description     String?
  // Last raw webhook payload — useful for support when a payment is "stuck".
  lastWebhookAt   DateTime?
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            UserProfile      @relation(fields: [userId], references: [id])
  case            Case?            @relation(fields: [caseId], references: [id])
  servicePurchase ServicePurchase?

  @@index([userId])
  @@index([caseId])
  @@index([status])
  @@index([provider])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — "Dossier prêt" service + scholarship/visa kits
// ─────────────────────────────────────────────────────────────────────────────
// Catalog of fixed-price packages KPB sells (10k–25k FCFA range).
// "Dossier prêt" = CV + motivation letter + recommendation letters reviewed
// in French + English before submission. This is the concrete, tangible
// thing parents are willing to pay for — the rest of the app's perceived
// value funnels into this SKU.
//
// A ServicePackage is the product definition. A ServicePurchase is a user's
// instance of that product (paid via PaymentIntent). Deliverables (uploaded
// CV, cover letter, reviewed PDF) live under CaseDocument on the linked case
// — we don't duplicate storage here.

model ServicePackage {
  id             String                 @id @default(cuid())
  // Stable slug used from the mobile app deep-links ("dossier-pret-fr-en").
  code           String                 @unique
  nameFr         String
  nameEn         String
  summaryFr      String
  summaryEn      String
  // Long-form marketing copy shown on the purchase screen.
  descriptionFr  String
  descriptionEn  String
  category       ServicePackageCategory
  // XOF integer (no subdivision). 25 000 FCFA = 25000.
  priceXOF       Int
  // What the student receives — bullet list rendered in the app.
  deliverablesFr String[]               @default([])
  deliverablesEn String[]               @default([])
  // Estimated turnaround e.g. "3 jours ouvrés".
  turnaroundFr   String?
  turnaroundEn   String?
  // Admin can hide a SKU without deleting it (keeps history intact).
  isActive       Boolean                @default(true)
  displayOrder   Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  purchases      ServicePurchase[]

  @@index([category])
  @@index([isActive])
}

model ServicePurchase {
  id                 String                @id @default(cuid())
  packageId          String
  userId             String
  // Optional — a purchase may be linked to an existing case for document flow.
  caseId             String?
  // Origin of the sale request: checkout, service_packages, case_detail, etc.
  source             String                @default("checkout")
  // Exactly one PaymentIntent per purchase. Null while we're still setting up.
  paymentIntentId    String?               @unique
  status             ServicePurchaseStatus @default(pending_payment)
  // Price snapshot at purchase time — protects against later SKU edits.
  amountXOF          Int
  // Freeform handoff notes from KPB back-office (not shown to student).
  internalNotes      String?
  deliveredAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  package            ServicePackage        @relation(fields: [packageId], references: [id])
  user               UserProfile           @relation(fields: [userId], references: [id])
  case               Case?                 @relation(fields: [caseId], references: [id])
  paymentIntent      PaymentIntent?        @relation(fields: [paymentIntentId], references: [id])
  studyReviewRequest StudyReviewRequest?

  @@index([packageId])
  @@index([userId])
  @@index([caseId])
  @@index([source])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Partner credibility layer
// ─────────────────────────────────────────────────────────────────────────────
// Campus France, AUF, Moroccan / Tunisian unis, and francophone banks
// (UBA, Ecobank, Orabank) for student-loan referrals. Each logo on the
// landing page is worth 1000 cold users — the mobile app renders this as
// the "Ils nous font confiance" strip.

model Partner {
  id            String             @id @default(cuid())
  // Stable slug like "campus-france-abidjan" — used in deep-links.
  slug          String             @unique
  nameFr        String
  nameEn        String
  category      PartnerCategory
  // ISO 3166-1 alpha-2 — lets the mobile app filter by "Banques au Sénégal" etc.
  countryCode   String?
  // Displayed as the tagline under the logo on the landing strip.
  taglineFr     String?
  taglineEn     String?
  descriptionFr String?
  descriptionEn String?
  logoUrl       String?
  websiteUrl    String?
  // For bank loans / agency referrals — a deep-link the student opens.
  referralUrl   String?
  // Featured partners pin to the top of the homepage strip.
  isFeatured    Boolean            @default(false)
  displayOrder  Int                @default(0)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  agreements    PartnerAgreement[]

  @@index([category])
  @@index([isActive])
  @@index([countryCode])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — "Salon KPB virtuel" (annual 2-day event)
// ─────────────────────────────────────────────────────────────────────────────
// Universities from Canada / France / Morocco answer questions live inside
// the app. The event itself (SalonEvent) owns the dates + branding. Each
// individual talk is a SalonSession with its own joinUrl (Jitsi / Zoom /
// Google Meet — we don't host video ourselves). Students RSVP via
// SalonRegistration so we can push reminders 24h and 1h before the session.

model SalonEvent {
  id            String           @id @default(cuid())
  slug          String           @unique
  nameFr        String
  nameEn        String
  // Edition year — used in the mobile app title ("Salon KPB Virtuel 2026").
  year          Int
  // Event window in UTC. Individual sessions fall within this range.
  startAt       DateTime
  endAt         DateTime
  heroImageUrl  String?
  descriptionFr String?
  descriptionEn String?
  status        SalonEventStatus @default(draft)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessions      SalonSession[]

  @@index([status])
  @@index([year])
}

model SalonSession {
  id              String              @id @default(cuid())
  eventId         String
  // Optional partner (e.g. Université de Montréal, Université Mohammed V).
  // Left nullable so KPB in-house sessions (welcome talk, Q&A panel) don't
  // need a Partner row.
  partnerId       String?
  titleFr         String
  titleEn         String
  descriptionFr   String?
  descriptionEn   String?
  // Host name(s) — freeform since they may not be KPB users.
  hostName        String?
  startAt         DateTime
  // Duration in minutes. 30/45/60 are the common slots.
  durationMinutes Int                 @default(45)
  // External meeting URL. We don't persist recordings — universities own those.
  joinUrl         String?
  recordingUrl    String?
  capacity        Int?
  status          SalonSessionStatus  @default(scheduled)
  displayOrder    Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  event           SalonEvent          @relation(fields: [eventId], references: [id])
  registrations   SalonRegistration[]

  @@index([eventId])
  @@index([partnerId])
  @@index([startAt])
  @@index([status])
}

model SalonRegistration {
  id           String       @id @default(cuid())
  sessionId    String
  userId       String
  // "registered" | "attended" | "cancelled" — kept as string to avoid a
  // dedicated enum for three values that rarely change.
  status       String       @default("registered")
  // KPB-78 reminder markers — set once each so the 24h/1h pushes never repeat.
  remindedAt   DateTime? // 24h-before reminder sent at
  reminded1hAt DateTime? // 1h-before reminder sent at
  createdAt    DateTime     @default(now())
  session      SalonSession @relation(fields: [sessionId], references: [id])
  user         UserProfile  @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Coach IA — persisted conversations (replaces the in-memory store)
// ─────────────────────────────────────────────────────────────────────────────

model CoachConversation {
  id        String         @id @default(cuid())

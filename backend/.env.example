# KPB Education — backend environment.
# Copy to `.env` and fill in. In production the app FAILS LOUD on boot if any
# value under "REQUIRED" is missing. Never commit a real .env.

# ─────────────────────────── REQUIRED ───────────────────────────
NODE_ENV=production
PORT=3000
# Exact Git commit; required once Competition Readiness is enabled.
KPB_BUILD_SHA=

# Postgres connection. With docker-compose these are assembled from
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB (set them in the ROOT .env).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/kpb?schema=public

# Secrets — generate long random strings (e.g. `openssl rand -hex 32`).
KPB_JWT_SECRET=
KPB_JWT_REFRESH_SECRET=
KPB_ADMIN_REFRESH_SECRET=

# Supabase Auth (students/parents authenticate via Supabase). SUPABASE_URL is
# mandatory; SUPABASE_JWT_SECRET is only needed for legacy HS256 projects.
# SUPABASE_SERVICE_ROLE_KEY is the SECRET key (Dashboard → Project Settings →
# API keys → "service_role" / sb_secret_…) — NOT the publishable/anon key. It
# lets account deletion remove a user's Supabase auth identity (GDPR/store). If
# unset, app data is still purged but the auth login record survives.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowed origins for CORS (admin web app, etc.).
CORS_ORIGINS=https://admin.kpbeducation.cloud

# API is behind one trusted Nginx reverse proxy in production. This lets
# Express/Nest use the real client IP for rate limiting without trusting an
# arbitrary X-Forwarded-For value from the public internet.
KPB_TRUST_PROXY_HOPS=1

# ────────────────────── FEATURE INTEGRATIONS ──────────────────────
# Each block is optional — leave blank to disable that feature.

# AI coach / document review (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Push notifications (OneSignal)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Magic-link email (Resend)
RESEND_API_KEY=
KPB_MAGIC_LINK_FROM=KPB Education <no-reply@kpbeducation.cloud>
KPB_MAGIC_LINK_WEB_BASE=https://app.kpbeducation.cloud
# Campaign email sender; falls back to KPB_MAGIC_LINK_FROM when blank.
KPB_CAMPAIGN_MAIL_FROM=

# Antivirus for uploads (ClamAV daemon, INSTREAM over TCP). Leave the host
# blank to skip scanning (dev). In docker-compose it defaults to the `clamav`
# sidecar. When set, scanning is FAIL-CLOSED: an unreachable scanner rejects
# uploads with 503 instead of letting unscanned files through.
CLAMAV_HOST=
CLAMAV_PORT=3310

# Force-update gate (mobile). Raise KPB_MIN_APP_VERSION to force clients below
# it onto the stores; leave at 0.0.0 (or blank) to never block.
KPB_MIN_APP_VERSION=
KPB_ANDROID_STORE_URL=
KPB_IOS_STORE_URL=

# Competition Readiness / "Mon atelier de candidature". These gates are
# fail-closed: production stays dark until each capability is explicitly on.
KPB_COMPETITION_READINESS_ENABLED=false
KPB_SUCCESS_LAB_ENABLED=false
KPB_APPLICATION_ARTIFACTS_ENABLED=false
KPB_APPLICATION_ARTIFACT_MAX_BYTES=10485760
KPB_STUDY_REVIEW_ENABLED=false
KPB_STUDY_REVIEW_SLA_HOURS=48
KPB_EVIDENCE_ACCESS_TTL_SECONDS=60
KPB_EVIDENCE_ACCESS_SECRET=
KPB_AI_DIAGNOSTIC_ENABLED=false
KPB_AI_DIAGNOSTIC_KILL_SWITCH=true
KPB_AI_DIAGNOSTIC_MODEL=
KPB_AI_DIAGNOSTIC_MIN_AGE=13
KPB_AI_DIAGNOSTIC_PROMPT_VERSION=success-lab-v1
KPB_AI_DIAGNOSTIC_MAX_INPUT_CHARS=8000
KPB_AI_DIAGNOSTIC_MAX_BILLABLE_INPUT_TOKENS=12000
KPB_AI_DIAGNOSTIC_MAX_OUTPUT_TOKENS=220
KPB_AI_DIAGNOSTIC_DAILY_CALL_CAP=100
KPB_AI_DIAGNOSTIC_USER_DAILY_ATTEMPT_CAP=3
KPB_AI_DIAGNOSTIC_MONTHLY_BUDGET_MICROS_USD=0
KPB_AI_DIAGNOSTIC_PRICE_VERSION=
KPB_AI_DIAGNOSTIC_CRITERIA_MAX_AGE_DAYS=180
KPB_SUCCESS_LAB_PILOT_COUNTRIES=NE,SN,CI
KPB_SUCCESS_LAB_ROLLOUT_PERCENT=0
KPB_FEATURE_ROLLOUT_SECRET=
# Required for pseudonymous, stable analytics attribution during a pilot.
KPB_ANALYTICS_ACTOR_SECRET=
# Durable domain-event worker. PostgreSQL leases prevent duplicate processing
# when several API replicas poll concurrently.
KPB_OUTBOX_BATCH_SIZE=10
KPB_OUTBOX_LEASE_MS=300000
KPB_OUTBOX_MAX_ATTEMPTS=8
KPB_OUTBOX_RETRY_BASE_MS=5000
KPB_OUTBOX_RETRY_CAP_MS=3600000
KPB_OUTCOME_EVIDENCE_ENABLED=false
KPB_OUTCOME_EVIDENCE_MAX_PENDING_PER_WORKSPACE=20
# Required in production; references are normalized and HMACed before storage.
KPB_OUTCOME_REFERENCE_HMAC_SECRET=
KPB_IMPACT_PUBLIC_STATS_ENABLED=false

# Parcours videos (YouTube Data API)
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=

# Flight price estimator (Kayak Price-Insights affiliate API). The backend
# proxies /api/flights/* so the app never sees the secret. Leave the api key or
# base url blank to disable — the app falls back to a browser deeplink.
KPB_KAYAK_API_KEY=
# Host only; the affiliate baseUri path is appended by the service.
KPB_KAYAK_BASE_URL=https://api.kayak.com
# User-Agent string Kayak assigned the affiliate (affects click/impression
# tracking). A sane default is used if left blank.
KPB_KAYAK_USER_AGENT=

# Document uploads — EITHER S3-compatible object storage…
KPB_S3_ENDPOINT=
KPB_S3_REGION=
KPB_S3_BUCKET=
KPB_S3_ACCESS_KEY_ID=
KPB_S3_SECRET_ACCESS_KEY=
# Only used to map database records created before private downloads. New
# uploads store an opaque storage:// reference and do not need a public bucket.
KPB_S3_PUBLIC_BASE_URL=
KPB_S3_FORCE_PATH_STYLE=
# …OR local disk (used when the S3 vars are unset)
KPB_UPLOADS_DIR=
# Legacy mapping only; this no longer exposes files through the API.
KPB_UPLOADS_PUBLIC_URL=

# MVP launch lock (true = hide V1.1+ modules). Defaults to enabled.
KPB_MVP_ONLY=true
